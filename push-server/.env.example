# Copy to .env and fill in from the Apple Developer portal.
# APNs auth key: Certificates, IDs & Profiles → Keys → (+) → Apple Push
# Notifications service (APNs). Download the .p8 ONCE and put it at
# push-server/secrets/AuthKey.p8

APNS_KEY_ID=ABCDE12345          # the key's Key ID
APNS_TEAM_ID=A1B2C3D4E5         # your 10-char Apple Team ID
APNS_DEFAULT_ENV=sandbox        # sandbox for debug/TestFlight, production for App Store
